# Port de l'interface (Pilot l'injecte à la création). Next lit la variable PORT.
PORT=3000

# Secret de signature de session (généré par post-init.sh). NE PAS committer .env
AUTH_SECRET=change-me-generate-a-long-random-string

# Compte admin de CETTE interface (un par interface).
# ADMIN_PASSWORD_HASH = bcrypt du mot de passe, généré par `npm run seed:admin`.
ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD_HASH=
